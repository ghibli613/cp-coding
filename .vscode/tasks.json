{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++.exe compile active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-g",
                "-Winvalid-pch",
                "-Wall",
                "-O2",
                "-Wl,--stack=268435456",
                "-Wextra",
                "-pedantic",
                "-std=c++20",
                "-D_GLIBCXX_DEBUG",
                "-D_GLIBCXX_DEBUG_PEDANTIC",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "C/C++: g++.exe run active file",
            "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [
                "0<",
                "_in.txt",
                "1>",
                "_out.txt",
                "2>&1"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "C/C++: g++.exe stress test active file",
            "command": "stress.bat",
            "args": [
                "${fileDirname}\\${fileBasenameNoExtension}_gen.exe",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${fileDirname}\\${fileBasenameNoExtension}_good.exe"
            ],
            "group": {
                "kind": "none",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}